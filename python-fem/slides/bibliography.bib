
@article{ACKROYD19891,
  title    = {Iteration and extrapolation methods for the approximate solution of the even-parity transport equation for systems with voids},
  journal  = {Annals of Nuclear Energy},
  volume   = {16},
  number   = {1},
  pages    = {1-32},
  year     = {1989},
  issn     = {0306-4549},
  doi      = {https://doi.org/10.1016/0306-4549(89)90117-5},
  url      = {https://www.sciencedirect.com/science/article/pii/0306454989901175},
  author   = {R.T. Ackroyd and N.S. Riyait},
  abstract = {Conventional finite-element solutions of the even-parity transport equation for systems with voids treat the void as a region of low absorption. This treatment tends to give physically-unacceptable solutions to void problems as the void cross-section tends to zero. An explanation for the effect is proposed. Biased finite elements are used in two ways to obtain physically-acceptable solutions for the void regions. Two new methods are described and tested. The iterative method synthesizes finite-element solution using a sequence of problems with constant absorptions in the void regions. The sequence is terminated when the fluxes in the void regions become steady. The extrapolation method obtains a best approximation to the void solution by combining two or more independent biased trial functions in an optimum way. The extrapolation method is further subdivided into elementary and nodal or multiparameter extrapolation. The relevant theory of both the iteration and extrapolation methods is given. Several 2-D test problems using the above methods have been investigated. Results are compared with those obtained with other numerical methods and almost analytical results of the point kernel method for voids surrounded by purely absorbing media.}
}

